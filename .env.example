# Firebase Configuration
# You can get the JSON file from Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
# and map the values to these variables.
FIREBASE_TYPE=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_UNIVERSE_DOMAIN=googleapis.com

# CORS
ALLOWED_ORIGINS=https://agroserv.netlify.app,http://localhost:3000

# Google Gemini / AI
GEMINI_API_KEY=SUA_NOVA_CHAVE_AQUI
GEMINI_MODEL=gemini-2.5-flash

